# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme123

# ── Blockchain ────────────────────────────────────────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key_here
# Auto-derived from ALCHEMY_API_KEY — override only if using a different RPC
# ARBITRUM_RPC=wss://arb-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# ── Bot Wallet (KEEP PRIVATE — never commit) ──────────────────────────────────
PRIVATE_KEY=0x_your_private_key_here
BOT_ADDRESS=0x_your_wallet_address_here



# ── External APIs ─────────────────────────────────────────────────────────────
ARBISCAN_API_KEY=your_arbiscan_api_key_here
ONEINCH_API_KEY=your_1inch_api_key_here
