{
  "name": "copy-trading-agent",
  "version": "1.0.0",
  "description": "Autonomous crypto copy trading agent with hybrid decision-making and Telegram interface",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node dist/db/migrate.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f agent",
    "docker:restart": "docker-compose restart agent",
    "docker:rebuild": "docker-compose up -d --build agent",
    "add-wallet": "tsx scripts/add-wallet.ts",
    "test-telegram": "tsx scripts/test-telegram.ts",
    "db:shell": "docker exec -it copy-trading-db psql -U trader -d copy_trading",
    "redis:shell": "docker exec -it copy-trading-redis redis-cli"
  },
  "keywords": [
    "crypto",
    "trading",
    "bot",
    "defi",
    "arbitrum",
    "ethereum"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "axios": "^1.7.9",
    "bullmq": "^5.26.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^6.34.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.21.44",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
